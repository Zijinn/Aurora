{
  "name": "@aurora/web",
  "version": "0.1.11",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "tsc -b && vite build",
    "build:desktop": "node scripts/generate-icons.mjs && tsc -b && vite build --mode desktop && node scripts/check-desktop-html.mjs",
    "dev": "vite",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:icons": "node scripts/generate-icons.mjs",
    "lint": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-virtual": "^3.13.18",
    "@wailsio/runtime": "3.0.0-alpha.97",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "workbox-window": "^7.4.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  }
}
