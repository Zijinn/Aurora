{
  "name": "cairn",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm --dir web build",
    "dev": "pnpm --parallel dev:server dev:web",
    "dev:server": "go run ./cmd/cairn-server",
    "dev:web": "pnpm --dir web dev",
    "desktop:dev": "go run -tags desktop ./cmd/cairn-desktop",
    "format": "gofmt -w cmd internal && pnpm --dir web format",
    "lint": "go vet ./... && pnpm --dir web lint",
    "test": "go test ./... && pnpm --dir web test",
    "typecheck": "pnpm --dir web typecheck"
  }
}
